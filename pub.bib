@article{ArtificialReview25,
	author = {Yashar Mousavi and Parastoo Akbari and Rashin Mousavi and Arash Mousavi and Ibrahim Küçükdemiral and Afef Fekih and Ümit Çalı},
	title = {QRL-AFOFA: Q-Learning Enhanced Self-Adaptive Fractional Order Firefly Algorithm for Large-Scale and Dynamic Multiobjective Optimization Problems},
	journal = {Artificial Intelligence Review},
	year = {2026},
	volume = {117},
	doi = {https://doi.org/10.1007/s10462-026-11511-y},
	keywords = {J},
	abstract = {This paper introduces QRL-AFOFA, a Q-learning-enhanced adaptive fractional-order firefly algorithm developed to address the challenges of large-scale and dynamic multiobjective optimization problems. While fractional-order metaheuristics provide memory-driven search dynamics and reinforcement learning (RL) offers adaptive policy control, existing hybrid methods often face critical limitations such as parameter sensitivity, premature convergence, and poor diversity preservation. To overcome these challenges, QRL-AFOFA integrates five synergistic innovations: real-time adaptive tuning of fractional-order parameters, entropy-regularized Q-value updates, stagnation-aware restart strategies, reflection-based boundary handling, and dual-phase learning rate scheduling. The Q-learning framework autonomously adapts critical parameters while entropy regularization maintains the exploration-exploitation balance, and stagnation-aware mechanisms ensure the preservation of population diversity. Extensive experiments on the IEEE Congress on Evolutionary Computation (CEC2021) benchmark functions demonstrate that QRL-AFOFA consistently outperforms state-of-the-art algorithms across diverse problem categories. Statistical validation further confirmed its superior performance across multiobjective, large-scale, and dynamic optimization scenarios. The algorithm achieves exceptional performance in high-dimensional settings while eliminating manual parameter tuning requirements, positioning it as an intelligent, scalable optimization framework for complex real-world applications.},
}


@article{IEEE_Tran_Electrification,
	author = {Ali Can Erüst and Fatma Yıldız Taşcıkaraoğlu and Akın Taşcıkaraoğlu and Yashar Mousavi and  Ibrahim Beklan Küçükdemiral},
	title = {Dynamic Pricing and Scheduling of Mobile Charging Systems in Competitive Electric Vehicle Charging Networks},
	journal = {IEEE Transactions on Transportation Electrification},
	year = {2026},
	abstract = {
	The rapid expansion of electric vehicle (EV) adoption has led to growing demand on charging infrastructure, resulting in congestion, extended waiting times, and increased stress on distribution networks. Mobile charging systems (MCSs) provide a flexible, grid-independent complement to stationary charging stations; however, their large-scale deployment is constrained by pricing trade-offs, as high tariffs discourage EV users from adopting MCS services, while low tariffs weaken operator profitability and investment incentives. This paper proposes a dynamic optimization-based pricing framework in which MCS charging prices are explicitly determined as a key decision variable. The framework incorporates spatiotemporal EV demand, MCS mobility constraints, electricity procurement costs, battery degradation costs, and travel costs, while modeling EV user choice behavior through a unit value of time (VoT) parameter to reflect heterogeneous time sensitivity under different pricing conditions. The resulting mixed-integer linear programming model is evaluated on the Sioux Falls transportation network over a 24-hour horizon. Numerical results show that the proposed framework reduces average EV charging station (EVCS) waiting times by 38.8\%, with peak-hour reductions of up to 56.3\%. Compared to fixed-price benchmarks, operator profit increases by more than twofold while maintaining coordinated and feasible MCS energy management.},
	note = {Under Review},
	keywords = {J},
}





@article{2cf380f5bd764ed58b26c4325c5c10d3,  title     = "Sugeno based robust adaptive fuzzy sliding-mode controller for SISO nonlinear systems",   author    = "Küçükdemiral, Ibrahim B. and Galip Cansever",  year      = "2006",  volume    = "17",  pages     = "113--124",  journal   = "Journal of Intelligent and Fuzzy Systems",  doi = "https://doi.org/10.3233/IFS-2006-00284", publisher = "SAGE Publications Ltd",  number    = "2", abstract = "A robust adaptive Sugeno based fuzzy sliding mode controller equipped with a supervisory controller is considered for the control of nonlinear systems which significantly reduce computation via reducing the size of fuzzy rule base. Besides, all the system parameters such as control and state signals can be confined to a predefined bounded region by use of proposed control method. Also the proposed method does not need any information of the controlled plant. Tracking and regulation simulations on an inverted pendulum system highlights that the proposed method is superior than the classical Sugeno based fuzzy controllers for the control of ill-defined nonlinear systems.",}



@article{https://doi.org/10.1002/rnc.1637,
	author = {Parlakçı, M. N. Alpaslan and Küçükdemiral, İbrahim B.},
	title = {Robust delay-dependent {$\mathcal H_\infty$} control of time-delay systems with state and input delays},
	journal = {International Journal of Robust and Nonlinear Control},
	volume = {21},
	number = {9},
	pages = {974-1007},
	doi = {https://doi.org/10.1002/rnc.1637},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/rnc.1637},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/rnc.1637},
	abstract = {This paper studies the design problem of robust delay-dependent $\mathcal{H}_\infty$ controller for a class of time-delay control systems with time-varying state and input delays, which are assumed to be noncoincident. The system is subject to norm-bounded uncertainties and $\mathcal{L}_2$ disturbances. Based on the selection of an augmented form of Lyapunov-Krasovskii functional, first a Bounded Real Lemma (BRL) is obtained in terms of linear matrix inequalities (LMIs) such that the nominal, unforced time-delay system is guaranteed to be globally asymptotically stable with minimum allowable disturbance attenuation level. Extending BRL, sufficient delay-dependent criteria are developed for a stabilizing $\mathcal{H}_\infty$ controller synthesis involving a matrix inequality for which a nonlinear optimization algorithm with LMIs is proposed to get feasible solution to the problem. Moreover, for the case of existence of norm-bounded uncertainties, both the BRL and $\mathcal{H}_\infty$ stabilization criteria are easily extended by employing a well-known bounding technique. A plenty of numerical examples are given to illustrate the application of the proposed methodology of this note. The achieved numerical results on the maximum allowable delay bound and minimum allowable disturbance attenuation level are exhibited to be less conservative in comparison to those of existing methods in the literature.},
	year = {2011}
}


